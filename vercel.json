{
    "version": 2,
    "installCommand": "npm install --include=dev --prefix frontend && npm install --include=dev --prefix node-backend",
    "buildCommand": "npm --prefix node-backend run prisma:generate && npm --prefix frontend run build",
    "outputDirectory": "frontend/dist",
    "functions": {
        "api/index.js": {
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/health/",
            "destination": "/api/index.js"
        },
        {
            "source": "/media/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/static/uploads/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}