{
    "version": 2,
    "installCommand": "npm install --include=dev --prefix frontend && npm install --include=dev --prefix node-backend",
    "buildCommand": "npm --prefix node-backend run prisma:generate && npm --prefix frontend run build",
    "outputDirectory": "frontend/dist",
    "functions": {
        "api/index.js": {
            "maxDuration": 30
        }
    },
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/health/",
            "destination": "/api/index.js"
        },
        {
            "source": "/media/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/static/uploads/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/product/(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/login",
            "destination": "/index.html"
        },
        {
            "source": "/signup",
            "destination": "/index.html"
        },
        {
            "source": "/cart",
            "destination": "/index.html"
        },
        {
            "source": "/checkout",
            "destination": "/index.html"
        },
        {
            "source": "/order/(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/payment/(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/invoice/(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/dashboard",
            "destination": "/index.html"
        },
        {
            "source": "/my-messages",
            "destination": "/index.html"
        },
        {
            "source": "/my-inbox",
            "destination": "/index.html"
        },
        {
            "source": "/wishlist",
            "destination": "/index.html"
        },
        {
            "source": "/admin/(.*)",
            "destination": "/index.html"
        }
    ]
}